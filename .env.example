# ===========================================================================
#  Copy this file to ".env" and fill in your keys.  NEVER commit .env to git.
#      cp .env.example .env        (mac/linux)
#      Copy-Item .env.example .env (Windows PowerShell)
# ===========================================================================

# --- OpenAI: embeddings + answers --- https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Qdrant Cloud: vector DB --- https://cloud.qdrant.io (create a free cluster)
QDRANT_URL=https://xxxxxxxx.cloud.qdrant.io:6333
QDRANT_API_KEY=...

# --- Hugging Face: download datasets --- https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# --- which LLM writes the answers: "openai" (default) or "anthropic" ---
LLM_BACKEND=openai
# ANTHROPIC_API_KEY=sk-ant-...        # only needed if LLM_BACKEND=anthropic

# ===========================================================================
#  FREE local testing (NO paid keys needed) - uncomment to run at $0:
#    EMBED_BACKEND=local       # free on-CPU embedding model instead of OpenAI
#    LLM_BACKEND=none          # extractive demo answer, no LLM call
#    QDRANT_LOCAL=1            # on-disk Qdrant instead of the cloud cluster
#    CORPUS_SUBSET_SIZE=200    # tiny corpus for a fast smoke test
# ===========================================================================
