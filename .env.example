# ===========================================================================
#  Copy this file to ".env" and fill in your keys.  NEVER commit .env to git.
#      cp .env.example .env        (mac/linux)
#      Copy-Item .env.example .env (Windows PowerShell)
# ===========================================================================

# --- Embeddings: "local" (free CPU) or "openai" ---
EMBED_BACKEND=local

# --- Qdrant Cloud: vector DB --- https://cloud.qdrant.io (create a free cluster)
QDRANT_URL=https://xxxxxxxx.cloud.qdrant.io:6333
QDRANT_API_KEY=...

# --- LLM backend: "gemini" (free), "openai", "anthropic", or "none" (extractive) ---
LLM_BACKEND=gemini

# --- Google Gemini 2.5 Flash (FREE via Google AI Studio) ---
#   Get a key at: https://aistudio.google.com/apikey
#   Add up to 3 keys from separate projects; they rotate automatically on rate-limit.
GEMINI_API_KEY=...
# GEMINI_API_KEY_2=...
# GEMINI_API_KEY_3=...

# --- OpenAI: needed only if EMBED_BACKEND=openai or LLM_BACKEND=openai ---
# OPENAI_API_KEY=sk-...

# --- Anthropic: needed only if LLM_BACKEND=anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Hugging Face: dataset download (optional; only needed for gated datasets) ---
# HF_TOKEN=hf_...

# ===========================================================================
#  Corpus tuning (all optional — defaults are sensible)
# ===========================================================================

# Snippets to collect per topic (4 topics × this = total corpus size).
# Default 3500 → ~14,000 snippets total. Raise for better coverage, lower for
# faster builds.
# CORPUS_PER_TOPIC_TARGET=3500

# Relevance threshold: abstain if the best reranker score is below this.
# -3.0 is a good balance — lets in-topic questions through while blocking
# clearly off-topic ones.
RELEVANCE_THRESHOLD=-3.0

# ===========================================================================
#  FREE local testing (NO paid keys needed) - use these settings to run
#  the entire pipeline at $0 with a tiny 200-snippet smoke-test corpus:
#
#    EMBED_BACKEND=local
#    LLM_BACKEND=none
#    QDRANT_LOCAL=1
#    CORPUS_PER_TOPIC_TARGET=50      # ~200 snippets, builds in seconds
# ===========================================================================
